---
const { title = "Home", description = "Authentic Italian fine dining in Downtown Barrie, Ontario since 2008." } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const logo = `${base}/il-buco-logo.jpg`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title === "Home" ? "Il Buco Ristorante · Barrie, Ontario" : `${title} · Il Buco Ristorante`}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,600&family=EB+Garamond:ital,wght@0,400;0,500;1,400&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>

    <nav class="nav" id="mainNav">
      <div class="nav-inner">
        <a href="/" class="nav-logo">
          <img src={logo} alt="Il Buco Ristorante" class="nav-logo-img" />
        </a>
        <button class="nav-toggle" id="navToggle" aria-label="Toggle menu">
          <span></span><span></span><span></span>
        </button>
        <ul class="nav-links" id="navLinks">
          <li><a href="/">Home</a></li>
          <li><a href="/menu">Menu</a></li>
          <li><a href="/specials">Daily Specials</a></li>
          <li><a href="/#reservations" class="nav-reserve">Reserve a Table</a></li>
        </ul>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-logo-wrap">
        <img src={logo} alt="Il Buco Ristorante" class="footer-logo-img" />
      </div>
      <div class="footer-inner">
        <div class="footer-col">
          <h4>Hours</h4>
          <p>Tuesday – Thursday</p><p class="hours-time">11:30am – 9:00pm</p>
          <p>Friday</p><p class="hours-time">11:30am – 10:00pm</p>
          <p>Saturday</p><p class="hours-time">5:00pm – 10:00pm</p>
          <p class="closed">Sunday & Monday — Closed</p>
        </div>
        <div class="footer-col">
          <h4>Reservations</h4>
          <p>Downtown Barrie, Ontario</p>
          <a href="tel:7057359595" class="footer-phone">705-735-9595</a>
          <p class="footer-note">Walk-ins welcome when available</p>
        </div>
        <div class="footer-col">
          <h4>Awards</h4>
          <p>🏆 Top 10 Most Romantic Restaurants in Canada</p>
          <p>🏆 Best Overall · Simcoe County</p>
          <p>🏆 TripAdvisor Hall of Fame</p>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© {new Date().getFullYear()} Il Buco Ristorante · All rights reserved</p>
        <p class="footer-est">Est. 2008 · Nostalgica Italian Cuisine</p>
      </div>
    </footer>

    <script>
      // Nav toggle
      document.getElementById('navToggle')?.addEventListener('click', () => {
        document.getElementById('navLinks')?.classList.toggle('open');
      });
      // Scroll effect
      window.addEventListener('scroll', () => {
        const nav = document.getElementById('mainNav');
        if (nav) nav.classList.toggle('scrolled', window.scrollY > 60);
      });
    </script>
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --crimson:     #8B1A1A;
    --crimson-dk:  #6B1313;
    --crimson-xdk: #4A0D0D;
    --crimson-lt:  #A82020;
    --cream:       #FDF8F2;
    --warm-white:  #FAF5EE;
    --parchment:   #F0E8D8;
    --gold:        #C8A96E;
    --gold-lt:     #E2C99A;
    --charcoal:    #1C1C1C;
    --ink:         #2D1A0E;
    --font-serif:  'Cormorant Garamond', 'EB Garamond', Georgia, serif;
    --font-body:   'EB Garamond', Georgia, serif;
    --font-sans:   'Montserrat', sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--cream);
    color: var(--ink);
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.7;
    overflow-x: hidden;
  }

  /* ── NAV ── */
  .nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 200;
    background: var(--crimson);
    transition: box-shadow 0.3s;
  }
  .nav.scrolled {
    box-shadow: 0 2px 30px rgba(74,13,13,0.4);
  }
  .nav-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2.5rem;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-logo { display: flex; align-items: center; text-decoration: none; }
  .nav-logo-img {
    height: 52px;
    width: auto;
    object-fit: contain;
    border-radius: 3px;
  }
  .nav-links {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0;
  }
  .nav-links li a {
    display: block;
    text-decoration: none;
    color: rgba(253,248,242,0.82);
    font-family: var(--font-sans);
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 500;
    padding: 0 1.4rem;
    height: 72px;
    line-height: 72px;
    border-bottom: 2px solid transparent;
    transition: color 0.2s, border-color 0.2s;
  }
  .nav-links li a:hover {
    color: var(--cream);
    border-bottom-color: rgba(253,248,242,0.4);
  }
  .nav-links .nav-reserve {
    background: rgba(0,0,0,0.25) !important;
    color: var(--cream) !important;
    border: 1px solid rgba(253,248,242,0.35) !important;
    border-bottom: 1px solid rgba(253,248,242,0.35) !important;
    height: auto !important;
    line-height: 1 !important;
    padding: 0.65rem 1.4rem !important;
    margin-left: 0.5rem;
    transition: background 0.2s, border-color 0.2s !important;
  }
  .nav-links .nav-reserve:hover {
    background: rgba(0,0,0,0.4) !important;
    border-color: var(--cream) !important;
  }
  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
  }
  .nav-toggle span {
    display: block;
    width: 26px;
    height: 2px;
    background: var(--cream);
  }

  @media (max-width: 820px) {
    .nav-toggle { display: flex; }
    .nav-links {
      display: none;
      flex-direction: column;
      align-items: stretch;
      position: absolute;
      top: 72px; left: 0; right: 0;
      background: var(--crimson-dk);
      padding: 0.5rem 0 1rem;
      gap: 0;
    }
    .nav-links.open { display: flex; }
    .nav-links li a {
      height: auto;
      line-height: 1;
      padding: 0.9rem 2rem;
      border-bottom: 1px solid rgba(253,248,242,0.08) !important;
    }
    .nav-links .nav-reserve {
      margin: 0.5rem 1.5rem 0 !important;
      text-align: center;
    }
  }

  /* ── FOOTER ── */
  .footer {
    background: var(--crimson-xdk);
    color: rgba(253,248,242,0.75);
    padding: 0;
    margin-top: 0;
  }
  .footer-logo-wrap {
    background: var(--crimson);
    display: flex;
    justify-content: center;
    padding: 3rem 2rem;
    border-bottom: 1px solid rgba(253,248,242,0.1);
  }
  .footer-logo-img {
    height: 90px;
    width: auto;
    object-fit: contain;
    border-radius: 4px;
  }
  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 4rem 2rem 3rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
  }
  .footer-col h4 {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold-lt);
    margin-bottom: 1.2rem;
    font-weight: 600;
  }
  .footer-col p {
    font-size: 0.88rem;
    margin-bottom: 0.3rem;
    line-height: 1.6;
    color: rgba(253,248,242,0.65);
  }
  .hours-time { color: rgba(253,248,242,0.9) !important; font-weight: 500; margin-bottom: 0.75rem !important; }
  .closed { color: rgba(253,248,242,0.35) !important; margin-top: 0.5rem; font-style: italic; }
  .footer-phone {
    display: block;
    font-family: var(--font-serif);
    font-size: 1.6rem;
    color: var(--gold-lt);
    text-decoration: none;
    margin: 0.5rem 0;
    font-style: italic;
  }
  .footer-phone:hover { color: var(--cream); }
  .footer-note { font-size: 0.75rem !important; color: rgba(253,248,242,0.4) !important; font-style: italic; }
  .footer-bottom {
    border-top: 1px solid rgba(253,248,242,0.08);
    text-align: center;
    padding: 1.5rem 2rem;
  }
  .footer-bottom p { font-size: 0.75rem; color: rgba(253,248,242,0.35); margin: 0.2rem 0; }
  .footer-est { font-style: italic; }

  @media (max-width: 768px) {
    .footer-inner { grid-template-columns: 1fr; gap: 2.5rem; }
  }

  /* ── SHARED UTILITIES ── */
  .label {
    font-family: var(--font-sans);
    font-size: 0.62rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--crimson);
    font-weight: 600;
    display: block;
    margin-bottom: 0.6rem;
  }
  .label.light { color: var(--gold-lt); }

  .section-title {
    font-family: var(--font-serif);
    font-size: clamp(2.4rem, 4.5vw, 3.8rem);
    font-weight: 400;
    line-height: 1.1;
    color: var(--ink);
  }
  .section-title.light { color: var(--cream); }
  .section-title em { font-style: italic; color: var(--crimson); }
  .section-title.light em { color: var(--gold-lt); }

  .rule {
    display: block;
    width: 48px;
    height: 2px;
    background: var(--crimson);
    margin: 1.4rem 0;
  }
  .rule.light { background: var(--gold); }
  .rule.center { margin: 1.4rem auto; }

  .btn {
    display: inline-block;
    text-decoration: none;
    font-family: var(--font-sans);
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 600;
    padding: 0.9rem 2.2rem;
    transition: all 0.22s;
    cursor: pointer;
    border: none;
    line-height: 1;
  }
  .btn-crimson { background: var(--crimson); color: var(--cream); border: 2px solid var(--crimson); }
  .btn-crimson:hover { background: var(--crimson-dk); border-color: var(--crimson-dk); }
  .btn-outline-cream { background: transparent; color: var(--cream); border: 1px solid rgba(253,248,242,0.5); }
  .btn-outline-cream:hover { border-color: var(--cream); background: rgba(253,248,242,0.08); }
  .btn-outline-crimson { background: transparent; color: var(--crimson); border: 2px solid var(--crimson); }
  .btn-outline-crimson:hover { background: var(--crimson); color: var(--cream); }
  .btn-gold { background: var(--gold); color: var(--ink); border: 2px solid var(--gold); }
  .btn-gold:hover { background: var(--gold-lt); border-color: var(--gold-lt); }
</style>
